# Copy this file to `.env` or export variables manually in your shell.
# Do not commit real secrets.

# API key for image generation in `scripts/generate_image.py`
POLZA_AI_KEY=your_polza_ai_key_here

# Optional local virtualenv path hint
VENV_PATH=.venv

# Local secrets directory used by YouTube and Sheets scripts
SECRETS_DIR=.secrets

# Expected files inside `.secrets/`
# - youtube_client_secret.json
# - youtube_token.json
# - comments_sheet_id.txt
# - ideas_cache.json
# - fresh_comments.json

# Optional notes for local tools:
# - `scripts/export_pdf.py` expects `pandoc` in PATH
# - `scripts/transcribe_video.py` downloads Whisper model weights on first run
